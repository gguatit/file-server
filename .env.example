# 파일 서버 환경 변수 (Cloudflare Workers)

# Secret으로 설정해야 하는 변수
#   npx wrangler secret put API_KEY
#   npx wrangler secret put ADMIN_TOKEN_SECRET

# wrangler.toml에 설정된 변수:
# - MAX_UPLOAD_SIZE: 262144000 (250MB)
# - RATE_LIMIT_PER_MINUTE: 60
# - ALLOWED_ORIGIN: https://kalpha.mmv.kr
# - ADMIN_ID: kalpha
# - ADMIN_PW_HASH: SHA-256 해시값
